# Common presentation-quality PyMOL settings
bg_color white
set orthoscopic, on
set antialias, 2
set depth_cue, 0
set ray_shadows, 1
set ray_trace_mode, 1
set ray_opaque_background, on
set light_count, 4
set ambient, 0.14
set direct, 0.45
set reflect, 0.45
set shininess, 25
set power, 1.25
set specular, 1
set spec_direct, 0
set spec_count, -1
set specular_intensity, 0.2
set ray_shadow_decay_factor, 0
set ambient_occlusion_mode, 1
set ambient_occlusion_scale, 18
set ambient_occlusion_smooth, 10
set cartoon_fancy_helices, 1
set cartoon_sampling, 14
set cartoon_transparency, 0.45
set stick_radius, 0.22
set valence, 0
set label_size, 0
set line_width, 3
set stick_quality, 18
set sphere_quality, 3
set surface_quality, 1
viewport 1600, 1200

# After adjusting the camera manually, render with:
# ray 3200, 2400
# png /absolute/path/to/output.png, dpi=300
